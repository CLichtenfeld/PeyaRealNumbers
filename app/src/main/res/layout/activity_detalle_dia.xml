<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <!-- CONTENEDOR PARA CAPTURA -->
    <LinearLayout
        android:id="@+id/layoutCapture"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/app_background">

        <!-- 1. CABECERA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvDetalleFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lunes, 27/03/26"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                <TextView
                    android:id="@+id/tvDetalleTiempoTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiempo Total: 00:00:00"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDetalleMontoTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"/>
        </LinearLayout>

        <!-- 2. DASHBOARD DE MÉTRICAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingHorizontal="12dp"
            android:paddingBottom="16dp">

            <!-- Km Real -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@color/card_real_km_bg">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="Km Real"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/card_real_km_text"/>
                        <ImageView
                            android:id="@+id/ivInfoRealKm"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_alignParentEnd="true"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="@color/card_real_km_text" />
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tvDetalleTotalReal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 km"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/card_real_km_text"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- $/Km Real -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@color/card_pago_km_bg">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="$/Km Real"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/card_pago_km_text"/>
                        <ImageView
                            android:id="@+id/ivInfoPagoKm"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_alignParentEnd="true"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="@color/card_pago_km_text" />
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tvDetallePesoPorKm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/card_pago_km_text"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Eficiencia -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="@color/card_eficiencia_bg">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="Eficiencia"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/card_eficiencia_text"/>
                        <ImageView
                            android:id="@+id/ivInfoEficiencia"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_alignParentEnd="true"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="@color/card_eficiencia_text" />
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tvDetalleEficiencia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/card_eficiencia_text"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- 3. EL MAPA -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/app_surface">
                <org.osmdroid.views.MapView
                    android:id="@+id/mapDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </androidx.cardview.widget.CardView>

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:background="@drawable/btn_rounded"
                android:backgroundTint="@color/accent_green"
                android:src="@android:drawable/ic_menu_share"
                android:elevation="12dp"
                android:padding="12dp"
                app:tint="@color/white" />
        </FrameLayout>

        <!-- 4. LISTA DE JORNADAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.8"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:background="@color/app_background">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESGLOSE POR JORNADA"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:id="@+id/tvDetalleTotalPlana"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Peya: 0.0km"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"/>
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSesiones"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>