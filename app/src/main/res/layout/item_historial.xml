<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistorialFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lun, 26 Mar"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvHistorialJornadas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 sesiones"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvHistorialExtraInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15.2 km | Vacío: 00:45:00"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"
                android:textStyle="italic"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvHistorialMonto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$56610"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"/>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginTop="4dp"
                android:src="@android:drawable/ic_media_play"
                android:alpha="0.3"
                app:tint="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
